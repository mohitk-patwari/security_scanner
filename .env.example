# =============================================================================
# NetGuard API server environment variables
# =============================================================================
# Operator-only file: this is for the NetGuard service host/admin.
# Customer repo users should configure GitHub Actions secrets only and should
# not be asked to provide LLM/provider keys from this file.
#
# Copy this file to .env and fill in the values before starting any service.
#
# IMPORTANT — two separate configuration locations:
#
#  1. This file (.env) → loaded by the Python services running on your server.
#     Contains DB credentials, LLM keys, HMAC secret, and service URLs.
#
#  2. GitHub repository secrets (Settings → Secrets and variables → Actions) →
#     used by the GitHub Actions workflow only. See "CI / GitHub Secrets" below.
#
# =============================================================================

# --- Database ----------------------------------------------------------------
# PostgreSQL connection string.
# Local dev fallback: if DATABASE_URL matches the localhost URL below AND the
# "netguard" role does not exist, the API falls back to SQLite at
# .netguard_dev.sqlite (set NETGUARD_SQLITE_FALLBACK=0 to disable that).
DATABASE_URL=postgresql://netguard:netguard@localhost:5432/netguard
# NETGUARD_SQLITE_FALLBACK=auto

# --- NetGuard service URLs ---------------------------------------------------
# Used by the Backend API (port 8000) to call the other Python services.
# Only change these if the services are running on different hosts/ports.
NETGUARD_API_URL=http://localhost:8000
PARSER_SERVICE_URL=http://localhost:8001
GRAPH_ENGINE_SERVICE_URL=http://localhost:8002
RISK_SCORER_SERVICE_URL=http://localhost:8003

# --- LLM (enrichment + autofix) ---------------------------------------------
# Set LLM_PROVIDER to gemini, groq, or openai and fill in the matching key.
# If no key is provided the risk scorer runs deterministic rules only (no AI
# severity adjustment, explanations, or autofix proposals).
LLM_PROVIDER=gemini

# Google AI Studio (https://aistudio.google.com) — used when LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq (https://console.groq.com) — used when LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI — used when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Deprecated alias — read by risk scorer if GEMINI_API_KEY is unset.
LLM_API_KEY=

# --- GitHub token (API server only) -----------------------------------------
# Optional. A GitHub Personal Access Token (PAT) with "repo" scope.
# Used by the API server to post autofix diff-preview comments on PRs via
# POST /api/fix-proposals/{id}/post-github-comment
# This is NOT the GitHub Actions github.token (that is injected automatically
# by the runner and used for scan summary PR comments — you do not put it here).
GITHUB_TOKEN=

# --- HMAC scan payload signing -----------------------------------------------
# Shared secret between this server and the GitHub Actions workflow.
# Must be byte-for-byte identical to the GitHub repo secret NETGUARD_SECRET.
# Generate a new value: openssl rand -hex 32
NETGUARD_SECRET=change-me-generate-with-openssl-rand-hex-32

# --- Frontend API origin (Vercel: set same URL in Project → Environment Variables) ---
VITE_API_BASE_URL=http://localhost:8000

# --- CORS (required for Vercel → EC2 browser calls) ---------------------------
# Comma-separated exact origins, e.g. https://net-guard-steel.vercel.app
# NETGUARD_CORS_ORIGINS=https://net-guard-steel.vercel.app
# Default regex also allows https://*.vercel.app if NETGUARD_CORS_ORIGINS is unset.
# NETGUARD_CORS_ORIGIN_REGEX=https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$|^https://[a-z0-9-]+\\.vercel\\.app$

# =============================================================================
# CI / GitHub Secrets  (do NOT put these in .env — they go in GitHub)
# =============================================================================
# The following variables are needed only in GitHub Actions.
# Add them under: your repo → Settings → Secrets and variables → Actions
#
#   NETGUARD_API_URL   = public URL of this API (e.g. https://xxxx.ngrok-free.app)
#                        No trailing /api. ngrok http 8000 gives you this URL.
#   NETGUARD_SECRET    = same value as NETGUARD_SECRET above
#   NETGUARD_API_KEY   = your org's API key from POST /api/auth/login
#                        (sign up via POST /api/auth/signup first)
#   NETGUARD_UI_URL    = (optional) public URL of the frontend for PR comment links
#
# The workflow (.github/workflows/netguard.yml) automatically:
#   - Triggers on PR open / update / reopen
#   - Collects ALL .tf / .yaml / .yml files tracked in the PR branch
#   - Signs the payload and posts to POST /api/scan
#   - Adds a findings summary comment to the PR
#   - Blocks the merge if any non-overridden HIGH or CRITICAL finding exists
# =============================================================================
