# Local development: copy to frontend/.env (do not commit .env)
VITE_API_BASE_URL=http://localhost:8000

# Vercel production: leave VITE_API_BASE_URL unset in the Vercel dashboard.
# The production build uses same-origin /api/* proxied to EC2 via vercel.json.
# Optional explicit value: https://net-guard-steel.vercel.app

# Optional: full URL to your netguard.yml on GitHub — shows a "View workflow on GitHub" link on the Scans page.
# Example: https://github.com/owner/repo/blob/main/.github/workflows/netguard.yml
VITE_GITHUB_WORKFLOW_URL=

# Optional: label shown next to the typical workflow path (defaults to a placeholder if unset).
VITE_CI_REPO_LABEL=your-org/your-iac-repo
